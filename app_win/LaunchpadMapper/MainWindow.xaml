<Window x:Class="LaunchpadMapper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Launchpad Mapper" Height="820" Width="1100" MinWidth="900" MinHeight="640" Background="#111827" Foreground="#E5E7EB">
    <Window.Resources>
        <!-- Dark theme: rounded buttons and consistent spacing -->
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
        <SolidColorBrush x:Key="BtnBg" Color="#1F2937"/>
        <SolidColorBrush x:Key="BtnBgHover" Color="#374151"/>
        <SolidColorBrush x:Key="BtnBgPressed" Color="#2563EB"/>
        <SolidColorBrush x:Key="BtnBorder" Color="#374151"/>
        <SolidColorBrush x:Key="InputBg" Color="#111827"/>
        <SolidColorBrush x:Key="InputBorder" Color="#374151"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E5E7EB"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource BtnBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BtnBgHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource BtnBgPressed}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F3A5F"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#243B53"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
    </Window.Resources>
    <DockPanel Margin="8">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel Orientation="Vertical" MinWidth="420">
                <TextBlock Text="MIDI Input (auto-selected)" FontWeight="Bold"/>
                <ComboBox x:Name="ComboMidiIn" Margin="0,4,0,8" IsEnabled="False"/>
                <TextBlock Text="MIDI Output (auto-selected)" FontWeight="Bold"/>
                <ComboBox x:Name="ComboMidiOut" Margin="0,4,0,8" IsEnabled="False"/>
                <!-- Use WrapPanel so buttons wrap when window is narrow and remain visible -->
                <WrapPanel Orientation="Horizontal" Margin="0,4,0,0" ItemHeight="30" ItemWidth="110">
                    <Button x:Name="BtnRefresh" Content="Refresh" Width="90" Click="BtnRefresh_Click" Margin="0,0,8,0" IsEnabled="False"/>
                    <Button x:Name="BtnConnect" Content="Connect" Width="90" Margin="0,0,8,0" Click="BtnConnect_Click"/>
                    <Button x:Name="BtnDisconnect" Content="Disconnect" Width="90" Margin="0,0,8,0" Click="BtnDisconnect_Click" IsEnabled="False"/>
                    <Button x:Name="BtnAutoScan" Content="Auto-Scan" Width="90" Margin="0,0,8,0" Click="BtnAutoScan_Click" IsEnabled="False"/>
                    <Button x:Name="BtnMidiMonitor" Content="MIDI Monitor" Width="110" Margin="0,0,8,0" Click="BtnMidiMonitor_Click"/>
                    <Button x:Name="BtnVerifyGrid" Content="Verify Grid" Width="110" Margin="0,0,8,0" Click="BtnVerifyGrid_Click"/>
                    <Button x:Name="BtnSettings" Content="Settings" Width="100" Click="BtnSettings_Click"/>
                </WrapPanel>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="16,0,0,0" Width="380">
                <TextBlock Text="Status" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,6">
                    <Button x:Name="BtnClearLog" Content="Clear Log" Width="100" Click="BtnClearLog_Click"/>
                    <CheckBox x:Name="ChkVerboseMidi" Content="Verbose MIDI" Margin="12,4,0,0" Checked="ChkVerboseMidi_Checked" Unchecked="ChkVerboseMidi_Unchecked"/>
                </StackPanel>
                <TextBox x:Name="TxtStatus" Width="380" Height="260" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </StackPanel>

        <!-- Removed on-screen pads. Configure per-pad colors in Settings. -->
    </DockPanel>
</Window>
