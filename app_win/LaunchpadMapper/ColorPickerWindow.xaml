<Window x:Class="LaunchpadMapper.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LaunchpadMapper.Controls"
        Title="Pick Color" Height="420" Width="720" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="8">
        <local:ColorWheelPicker x:Name="Picker" DockPanel.Dock="Top" Height="320" Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click"/>
            <Button Content="Cancel" Width="80" IsCancel="True" Click="BtnCancel_Click"/>
        </StackPanel>
    </DockPanel>
</Window>
