<Window x:Class="LaunchpadMapper.MacroHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macro Help" Height="520" Width="640">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Macro syntax" FontSize="16" FontWeight="Bold"/>
                <TextBlock TextWrapping="Wrap" Margin="0,8,0,0">
                    Enter text and macro tokens in the Hotkey box. Text is typed literally. Tokens in braces perform special actions.
                </TextBlock>

                <TextBlock Text="Tokens" FontSize="14" FontWeight="Bold" Margin="0,12,0,0"/>
                <TextBlock TextWrapping="Wrap" Text="{}{ENTER}, {RETURN}, {TAB}, {ESC}, {ESCAPE}, {SPACE}, {BACKSPACE}, {BKSP}, {BS}, {DELETE}, {DEL}, {UP}, {DOWN}, {LEFT}, {RIGHT}"/>

                <TextBlock Text="Wait/Delay" FontSize="14" FontWeight="Bold" Margin="0,12,0,0"/>
                <TextBlock TextWrapping="Wrap" Text="{}{WAIT 200}  - waits the given milliseconds before continuing."/>

                <TextBlock Text="Chords (modifiers + key)" FontSize="14" FontWeight="Bold" Margin="0,12,0,0"/>
                <TextBlock TextWrapping="Wrap" Text="{}Use plus signs inside braces, e.g. {CTRL+S}, {CTRL+SHIFT+P}, {ALT+TAB}, {WIN+R}"/>

                <TextBlock Text="Plain text" FontSize="14" FontWeight="Bold" Margin="0,12,0,0"/>
                <TextBlock TextWrapping="Wrap" Text="{}Any characters outside braces are typed as-is. Example: Hello{ENTER}World!"/>

                <TextBlock Text="Sequences (optional legacy)" FontSize="14" FontWeight="Bold" Margin="0,12,0,0"/>
                <TextBlock TextWrapping="Wrap" Text="You may also enter a semicolon-separated list like A;B;C which is treated as individual key presses. Prefer macros above for mixed text and keys."/>

                <TextBlock Text="Examples" FontSize="14" FontWeight="Bold" Margin="0,12,0,0"/>
                <Border BorderBrush="Gray" BorderThickness="1" Padding="8">
                    <StackPanel>
                        <TextBlock Text="{}teST {ENTER}" FontFamily="Consolas"/>
                        <TextBlock Text="{}Hello{WAIT 200}{ENTER}World" FontFamily="Consolas" Margin="0,4,0,0"/>
                        <TextBlock Text="{}{CTRL+S}" FontFamily="Consolas" Margin="0,4,0,0"/>
                        <TextBlock Text="{}{ALT+TAB}{WAIT 100}{ENTER}" FontFamily="Consolas" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Notes" FontSize="14" FontWeight="Bold" Margin="0,12,0,0"/>
                <TextBlock TextWrapping="Wrap">
                    - Typing uses the clipboard when possible for reliability; if clipboard paste fails, it falls back to typing characters.
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Width="100" IsDefault="True" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
