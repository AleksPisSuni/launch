<UserControl x:Class="LaunchpadMapper.Controls.ColorWheelPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             MinWidth="440" MinHeight="280">
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="36"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Color wheel with selection marker -->
        <Grid x:Name="WheelRoot" ClipToBounds="True"
              MouseLeftButtonDown="WheelImage_MouseDown" MouseMove="WheelImage_MouseMove" MouseLeftButtonUp="WheelImage_MouseUp">
            <Image x:Name="WheelImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Canvas x:Name="MarkerCanvas" IsHitTestVisible="False">
                <Ellipse x:Name="WheelMarker" Width="10" Height="10" Stroke="White" StrokeThickness="2" Fill="Transparent"/>
            </Canvas>
        </Grid>

        <!-- Brightness (Value) slider -->
        <Border Grid.Column="1" Margin="8,0,0,0" CornerRadius="4" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <Rectangle x:Name="ValueGradient" RadiusX="4" RadiusY="4"/>
                <Slider x:Name="ValueSlider" Orientation="Vertical" Minimum="0" Maximum="100" ValueChanged="ValueSlider_ValueChanged"/>
            </Grid>
        </Border>

        <!-- Fields -->
        <StackPanel Grid.Column="3" Orientation="Vertical">
            <TextBlock Text="HSL" FontWeight="Bold" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="H" Width="20" VerticalAlignment="Center"/>
                <xctk:IntegerUpDown x:Name="HUpDown" Minimum="0" Maximum="360" Width="70" ValueChanged="Hsl_Changed"/>
                <TextBlock Text="S" Width="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <xctk:IntegerUpDown x:Name="SUpDown" Minimum="0" Maximum="100" Width="70" ValueChanged="Hsl_Changed"/>
                <TextBlock Text="L" Width="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <xctk:IntegerUpDown x:Name="LUpDown" Minimum="0" Maximum="100" Width="70" ValueChanged="Hsl_Changed"/>
            </StackPanel>

            <TextBlock Text="RGB" FontWeight="Bold" Margin="0,6,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="R" Width="20" VerticalAlignment="Center"/>
                <xctk:IntegerUpDown x:Name="RUpDown" Minimum="0" Maximum="255" Width="70" ValueChanged="Rgb_Changed"/>
                <TextBlock Text="G" Width="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <xctk:IntegerUpDown x:Name="GUpDown" Minimum="0" Maximum="255" Width="70" ValueChanged="Rgb_Changed"/>
                <TextBlock Text="B" Width="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <xctk:IntegerUpDown x:Name="BUpDown" Minimum="0" Maximum="255" Width="70" ValueChanged="Rgb_Changed"/>
            </StackPanel>

            <TextBlock Text="# (Hex)" FontWeight="Bold" Margin="0,6,0,6"/>
            <DockPanel>
                <TextBlock Text="#" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="HexBox" Width="120" TextChanged="HexBox_TextChanged"/>
                <Rectangle Width="24" Height="24" Stroke="#666" StrokeThickness="1" Margin="8,0,0,0">
                    <Rectangle.Fill>
                        <SolidColorBrush x:Name="PreviewBrush"/>
                    </Rectangle.Fill>
                </Rectangle>
            </DockPanel>
        </StackPanel>

        <!-- Selected color preview and instructions -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="Selected:" VerticalAlignment="Center"/>
            <Rectangle Width="28" Height="18" Stroke="#555" StrokeThickness="1" Margin="8,0,0,0">
                <Rectangle.Fill>
                    <SolidColorBrush x:Name="SelectedBrush"/>
                </Rectangle.Fill>
            </Rectangle>
            <TextBlock x:Name="SelectedText" Margin="8,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>