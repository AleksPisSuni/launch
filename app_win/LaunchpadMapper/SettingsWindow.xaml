<Window x:Class="LaunchpadMapper.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LaunchpadMapper.Models"
        xmlns:conv="clr-namespace:LaunchpadMapper.Utils"
        Title="Settings" Height="640" Width="980">
    <Window.Resources>
        <conv:ColorStringToColorConverter x:Key="ColorStringToColorConverter"/>
    </Window.Resources>
    <DockPanel Margin="8">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button x:Name="BtnAdd" Content="Add Mapping" Width="120" Click="BtnAdd_Click"/>
            <Button x:Name="BtnRemove" Content="Remove Mapping" Width="140" Margin="8,0,0,0" Click="BtnRemove_Click"/>
            <Button x:Name="BtnEdit" Content="Edit Selected…" Width="140" Margin="8,0,0,0" Click="BtnEdit_Click"/>
            <Button x:Name="BtnClear" Content="Clear Mapping" Width="140" Margin="8,0,0,0" Click="BtnClear_Click"/>
            <Button x:Name="BtnSave" Content="Save All" Width="100" Margin="8,0,0,0" Click="BtnSave_Click"/>
            <Button x:Name="BtnReload" Content="Reload" Width="100" Margin="8,0,0,0" Click="BtnReload_Click"/>
            <TextBlock x:Name="TxtPadCaptureStatus" Text="Press a pad to select…" Visibility="Collapsed" Margin="16,6,0,0"/>
            <Button x:Name="BtnCancelCapture" Content="Cancel" Width="80" Margin="8,0,0,0" Visibility="Collapsed" Click="BtnCancelCapture_Click"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Mappings list: edit Key and Type inline; other fields via details below -->
            <DataGrid x:Name="GridMappings" Grid.Row="0" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,4,0,8" SelectionChanged="GridMappings_SelectionChanged" CurrentCellChanged="GridMappings_CurrentCellChanged" CellEditEnding="GridMappings_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Key (r,c or note:N)" Binding="{Binding Key}" Width="160" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Action.Type}" IsReadOnly="True" Width="120" />
                    <DataGridTemplateColumn Header="Color" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Click="BtnRowColor_Click" Tag="{Binding}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Rectangle Width="18" Height="18" Stroke="#444" StrokeThickness="1" Margin="0,0,6,0">
                                            <Rectangle.Fill>
                                                <SolidColorBrush Color="{Binding Action.Color, Converter={StaticResource ColorStringToColorConverter}}"/>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <TextBlock Text="Color…"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Details panel disabled due to stability; use Edit Selected… instead -->
            <Border Grid.Row="1" BorderBrush="#374151" BorderThickness="1" Padding="8" CornerRadius="6" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="TxtSelectedKey" Text="No selection" Margin="0,0,0,6"/>

                    <!-- Color controls -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Color:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Rectangle Width="24" Height="24" Stroke="#444" StrokeThickness="1" Margin="0,0,8,0">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding SelectedItem.Action.Color, ElementName=GridMappings, Converter={StaticResource ColorStringToColorConverter}}"/>
                            </Rectangle.Fill>
                        </Rectangle>
                        <TextBlock x:Name="TxtCurrentColor" Text="" Margin="0,5,0,0" Width="100"/>
                        <Button Content="Pick color…" Margin="8,0,0,0" Click="BtnCustomColor_Click"/>
                    </StackPanel>

                    <!-- Sound options (unused when collapsed) -->
                    <StackPanel x:Name="PanelSound" Visibility="Collapsed" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Path:" VerticalAlignment="Center" Width="60"/>
                            <TextBox x:Name="TxtPath" Width="360" TextChanged="TxtPath_TextChanged"/>
                            <Button x:Name="BtnBrowseSound" Content="Browse…" Margin="8,0,0,0" Click="BtnBrowseSound_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <CheckBox x:Name="ChkLoop" Content="Loop" Margin="0,4,0,0" Checked="ChkLoop_Checked" Unchecked="ChkLoop_Unchecked"/>
                            <CheckBox x:Name="ChkStopRetrigger" Content="Stop if pressed again" Margin="16,4,0,0" Checked="ChkStopRetrigger_Checked" Unchecked="ChkStopRetrigger_Unchecked"/>
                            <CheckBox x:Name="ChkPlayWhileHeld" Content="Play only while held" Margin="16,4,0,0" Checked="ChkPlayWhileHeld_Checked" Unchecked="ChkPlayWhileHeld_Unchecked"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Hotkey options (single field) -->
                    <StackPanel x:Name="PanelHotkey" Visibility="Collapsed" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Hotkey/Macro:" VerticalAlignment="Center" Width="100"/>
                            <TextBox x:Name="TxtHotkeyMacro" Width="420" TextChanged="TxtHotkeyMacro_TextChanged"/>
                            <Button x:Name="BtnTestMacro" Content="Test in Active Window" Margin="8,0,0,0" Click="BtnTestMacro_Click"/>
                        </StackPanel>
                        <TextBlock Text="Type text or tokens like {ENTER}, {TAB}, {ESC}, {WAIT 200}, or chords like {CTRL+S}." FontSize="11" Foreground="#666" Margin="100,4,0,0"/>
                    </StackPanel>

                    <!-- Command options -->
                    <StackPanel x:Name="PanelCommand" Orientation="Horizontal" Visibility="Collapsed" Margin="0,4,0,0">
                        <TextBlock Text="Cmd:" VerticalAlignment="Center" Width="60"/>
                        <TextBox x:Name="TxtCmd" Width="360" TextChanged="TxtCmd_TextChanged"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Bottom settings: Pulse + TTS -->
            <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,6,0,0">
                <!-- Pulse Settings -->
                <Border BorderBrush="#374151" BorderThickness="1" Padding="8" CornerRadius="6" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="Pulse Settings" FontWeight="Bold" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="Interval (ms):" VerticalAlignment="Center" Width="120"/>
                            <TextBox x:Name="TxtPulseInterval" Width="80" Text="50"/>
                        </StackPanel>
                        <!-- Pulse Test button removed per user request; pulsing is validated via real actions. -->
                    </StackPanel>
                </Border>

                <!-- TTS Settings -->
                <Border BorderBrush="#374151" BorderThickness="1" Padding="8" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Text-to-Speech" FontWeight="Bold" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="Provider:" VerticalAlignment="Center" Width="120"/>
                            <ComboBox x:Name="ComboTtsProvider" Width="200" DisplayMemberPath="Label">
                                <ComboBoxItem Content="windows"/>
                                <ComboBoxItem Content="elevenlabs"/>
                            </ComboBox>
                            <TextBlock Text=" Voice:" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <ComboBox x:Name="ComboTtsVoice" Width="360" DisplayMemberPath="Label" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="11Labs Key:" VerticalAlignment="Center" Width="120"/>
                            <PasswordBox x:Name="TxtELKey" Width="260"/>
                            <TextBlock Text=" Voice ID:" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <TextBox x:Name="TxtELVoice" Width="260"/>
                        </StackPanel>
                        <TextBlock Text="Note: Windows TTS works offline with local voices. ElevenLabs requires your API key and a Voice ID; audio is sent to ElevenLabs for synthesis when used." FontSize="11" Foreground="#666" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
