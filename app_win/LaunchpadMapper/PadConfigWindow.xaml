<Window x:Class="LaunchpadMapper.PadConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Pad Configuration" Height="360" Width="660" MinWidth="620" SizeToContent="Height">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Pad:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBlock x:Name="TxtPad" Grid.Row="0" Grid.Column="1" FontWeight="Bold"/>

        <TextBlock Text="Type:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
        <ComboBox x:Name="ComboType" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
            <ComboBoxItem>sound</ComboBoxItem>
            <ComboBoxItem>hotkey</ComboBoxItem>
            <ComboBoxItem>command</ComboBoxItem>
            <ComboBoxItem>tts</ComboBoxItem>
        </ComboBox>

        <TextBlock Text="Path (sound):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBox x:Name="TxtPath" Width="320"/>
            <Button Content="Browse" Width="60" Margin="8,0,0,0" Click="BtnBrowse_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
            <CheckBox x:Name="ChkLoop" Content="Loop"/>
            <CheckBox x:Name="ChkStopRetrigger" Content="Stop if pressed again" Margin="16,0,0,0"/>
            <CheckBox x:Name="ChkPlayWhileHeld" Content="Play only while held" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- Volume row (sound only, but harmless to show always) -->
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
            <TextBlock Text="Volume:" VerticalAlignment="Center" Width="60"/>
            <Slider x:Name="SldVolume" Minimum="0" Maximum="100" Width="220" TickFrequency="10" IsSnapToTickEnabled="False"/>
            <TextBlock x:Name="TxtVolPct" Margin="8,0,0,0" VerticalAlignment="Center" Width="48"/>
        </StackPanel>

        <TextBlock Text="Hotkey / Macro:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
        <TextBox x:Name="TxtHotkey" Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" MinWidth="300" HorizontalAlignment="Stretch"/>
        <!-- Buttons on their own row for clean layout on all DPIs -->
        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0">
            <Button x:Name="BtnRecord" Content="Record" Width="90" Click="BtnRecord_Click"/>
            <Button x:Name="BtnClearSeq" Content="Clear" Width="80" Margin="8,0,0,0" Click="BtnClearSeq_Click"/>
            <Button x:Name="BtnTestSeq" Content="Test" Width="80" Margin="8,0,0,0" Click="BtnTestSeq_Click"/>
            <Button x:Name="BtnHelp" Content="Help" Width="80" Margin="8,0,0,0" Click="BtnHelp_Click"/>
        </StackPanel>

        <TextBlock Text="Command:" Grid.Row="7" Grid.Column="0" VerticalAlignment="Top" Margin="0,8,0,0"/>
        <TextBox x:Name="TxtCmd" Grid.Row="7" Grid.Column="1" AcceptsReturn="True" Height="80"/>

        <StackPanel Orientation="Horizontal" Grid.Row="8" Grid.ColumnSpan="2" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Width="100" Click="BtnSave_Click"/>
            <Button Content="Cancel" Width="100" Margin="8,0,0,0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
