<Window x:Class="LaunchpadX.MacroEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macro Editor" Width="600" Height="440"
        Background="#111827" Foreground="#E5E7EB"
        ResizeMode="CanResize" MinWidth="500" MinHeight="360"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#E5E7EB"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#374151"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#9CA3AF" HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#374151"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Background" Value="#374151"/>
                                                <Setter Property="BorderBrush" Value="#4B5563"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#1F2937" BorderBrush="#4B5563"
                                        BorderThickness="1" CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="12"
                                                          ShadowDepth="4" Opacity="0.6"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button Content="OK" Click="BtnOk_Click"
                    Background="#1D4ED8" BorderBrush="#1E40AF"/>
        </StackPanel>

        <!-- Left: action list + buttons -->
        <DockPanel Width="190" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top" Text="Actions"
                       Foreground="#6B7280" FontSize="11" Margin="0,0,0,4"/>

            <!-- List controls -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="26"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="+ Add"  Click="BtnAdd_Click"    Padding="4,5"/>
                    <Button Grid.Column="2" Content="✕ Del"  Click="BtnRemove_Click" Padding="4,5"/>
                    <Button Grid.Column="4" Content="↑"      Click="BtnUp_Click"     Padding="4,5"/>
                    <Button Grid.Column="6" Content="↓"      Click="BtnDown_Click"   Padding="4,5"/>
                </Grid>
            </StackPanel>

            <ListBox x:Name="LstActions" SelectionChanged="LstActions_SelectionChanged"/>
        </DockPanel>

        <!-- Right: action editor -->
        <StackPanel x:Name="PanelEditor">
            <TextBlock Text="Action Editor" Foreground="#6B7280" FontSize="11" Margin="0,0,0,8"/>

            <!-- Type -->
            <TextBlock Text="Type" Margin="0,0,0,3"/>
            <ComboBox x:Name="CmbActionType" SelectionChanged="CmbActionType_SelectionChanged"
                      Margin="0,0,0,10">
                <ComboBoxItem Content="Hotkey"       Tag="hotkey"/>
                <ComboBoxItem Content="Type Text"    Tag="text"/>
                <ComboBoxItem Content="Play Sound"   Tag="sound"/>
                <ComboBoxItem Content="Run Command"  Tag="command"/>
                <ComboBoxItem Content="Delay only"   Tag="delay"/>
            </ComboBox>

            <!-- Delay before -->
            <TextBlock Text="Pause before action (ms)" Margin="0,0,0,3"/>
            <TextBox x:Name="TxtActionDelay" Text="0" Margin="0,0,0,10"
                     TextChanged="TxtActionDelay_TextChanged"/>

            <!-- Hotkey panel -->
            <StackPanel x:Name="PanelHotkey">
                <TextBlock Text="Keys  (e.g. Ctrl+S, F5)" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtKeys" TextChanged="TxtKeys_TextChanged"/>
            </StackPanel>

            <!-- Text panel -->
            <StackPanel x:Name="PanelText" Visibility="Collapsed">
                <TextBlock Text="Text to type" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtText" Height="70" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         TextChanged="TxtText_TextChanged"/>
            </StackPanel>

            <!-- Sound panel -->
            <StackPanel x:Name="PanelSound" Visibility="Collapsed">
                <TextBlock Text="Sound file path" Margin="0,0,0,3"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtSoundPath" TextChanged="TxtSoundPath_TextChanged"/>
                    <Button Grid.Column="2" Content="Browse" Click="BtnBrowseSound_Click" Padding="4,4"/>
                </Grid>
            </StackPanel>

            <!-- Command panel -->
            <StackPanel x:Name="PanelCommand" Visibility="Collapsed">
                <TextBlock Text="Executable" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtCommand" TextChanged="TxtCommand_TextChanged"/>
                <TextBlock Text="Arguments" Margin="0,8,0,3"/>
                <TextBox x:Name="TxtArguments" TextChanged="TxtArguments_TextChanged"/>
            </StackPanel>

            <!-- Delay panel -->
            <TextBlock x:Name="LblDelayHint" Visibility="Collapsed"
                       Text="Set the 'Pause before action (ms)' field above."
                       Foreground="#6B7280" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

    </DockPanel>
</Window>
