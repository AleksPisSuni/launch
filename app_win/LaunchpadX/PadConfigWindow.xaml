<Window x:Class="LaunchpadX.PadConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Pad" Width="420" Height="580"
        Background="#111827" Foreground="#E5E7EB"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#E5E7EB"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#374151"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#9CA3AF" HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#374151"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Background" Value="#374151"/>
                                                <Setter Property="BorderBrush" Value="#4B5563"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#1F2937" BorderBrush="#4B5563"
                                        BorderThickness="1" CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="12"
                                                          ShadowDepth="4" Opacity="0.6"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" x:Name="TitleLabel"
                   Text="Pad — Note 0" FontSize="15" FontWeight="SemiBold"
                   Foreground="#E5E7EB" Margin="0,0,0,16"/>

        <!-- Label + Color -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Label"/>
                <TextBox x:Name="TxtLabel"/>
                <TextBlock Text="Toggle mode" Margin="0,8,0,3"/>
                <CheckBox x:Name="ChkToggleMode" Content="Latch on/off with each press"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="LED Color"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtColor" Text="#FF4400" VerticalAlignment="Center"/>
                    <Border Grid.Column="2" x:Name="ColorPreview"
                            Width="36" Height="32" CornerRadius="5"
                            Background="#FF4400" VerticalAlignment="Center"
                            Cursor="Hand" ToolTip="Click to open color picker"
                            MouseLeftButtonDown="ColorPreview_Click">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                    </Border>
                </Grid>
                <Button x:Name="BtnPickColor" Content="Pick Color…"
                        Padding="6,5" Margin="0,0,0,6" Click="BtnPickColor_Click"/>
                <UniformGrid Rows="2" Columns="8">
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#FF2222" Click="ColorPreset_Click" Tag="#FF2222" ToolTip="Red"     BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#FF6600" Click="ColorPreset_Click" Tag="#FF6600" ToolTip="Orange"  BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#FFCC00" Click="ColorPreset_Click" Tag="#FFCC00" ToolTip="Yellow"  BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#88FF00" Click="ColorPreset_Click" Tag="#88FF00" ToolTip="Lime"    BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#00FF44" Click="ColorPreset_Click" Tag="#00FF44" ToolTip="Green"   BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#00FFCC" Click="ColorPreset_Click" Tag="#00FFCC" ToolTip="Cyan"    BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#0088FF" Click="ColorPreset_Click" Tag="#0088FF" ToolTip="Blue"    BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#8800FF" Click="ColorPreset_Click" Tag="#8800FF" ToolTip="Violet"  BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#FF0088" Click="ColorPreset_Click" Tag="#FF0088" ToolTip="Pink"    BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#FF4444" Click="ColorPreset_Click" Tag="#FF4444" ToolTip="Coral"   BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#FFAA33" Click="ColorPreset_Click" Tag="#FFAA33" ToolTip="Amber"   BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#FFFF33" Click="ColorPreset_Click" Tag="#FFFF33" ToolTip="Lemon"   BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#33FF99" Click="ColorPreset_Click" Tag="#33FF99" ToolTip="Mint"    BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#33CCFF" Click="ColorPreset_Click" Tag="#33CCFF" ToolTip="Sky"     BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#CC44FF" Click="ColorPreset_Click" Tag="#CC44FF" ToolTip="Purple"  BorderThickness="0"/>
                    <Button Width="16" Height="16" Padding="0" Margin="1" Background="#FFFFFF" Click="ColorPreset_Click" Tag="#FFFFFF" ToolTip="White"   BorderThickness="0"/>
                </UniformGrid>
            </StackPanel>
        </Grid>

        <!-- Type -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Action Type"/>
            <ComboBox x:Name="CmbType" SelectionChanged="CmbType_SelectionChanged">
                <ComboBoxItem Content="Hotkey"         Tag="hotkey"/>
                <ComboBoxItem Content="Type Text"      Tag="text"/>
                <ComboBoxItem Content="Play Sound"     Tag="sound"/>
                <ComboBoxItem Content="Run Command"    Tag="command"/>
                <ComboBoxItem Content="Stop All Sounds" Tag="stopall"/>
                <ComboBoxItem Content="Lightshow"       Tag="lightshow"/>
                <ComboBoxItem Content="MIDI Out"      Tag="midi"/>
                <ComboBoxItem Content="Macro"         Tag="macro"/>
                <ComboBoxItem Content="Volume Control" Tag="volume"/>
            </ComboBox>
        </StackPanel>

        <!-- Type-specific panels -->
        <Grid Grid.Row="3">

            <!-- Hotkey panel -->
            <StackPanel x:Name="PanelHotkey" Visibility="Visible">
                <TextBlock Text="Keys  (e.g. Ctrl+S, F5, Ctrl+Shift+Alt+F12)"/>
                <TextBox x:Name="TxtKeys"/>
            </StackPanel>

            <!-- Text panel -->
            <StackPanel x:Name="PanelText" Visibility="Collapsed">
                <TextBlock Text="Text to type"/>
                <TextBox x:Name="TxtText" Height="80" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>

            <!-- Sound panel -->
            <StackPanel x:Name="PanelSound" Visibility="Collapsed">
                <TextBlock Text="Sound file path (.wav / .mp3)"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtSoundPath"/>
                    <Button Grid.Column="2" Content="Browse" Click="BtnBrowse_Click" Padding="4,4"/>
                </Grid>
                <WrapPanel Margin="0,8,0,0">
                    <CheckBox x:Name="ChkLoop"            Content="Loop"/>
                    <CheckBox x:Name="ChkStopOnRetrigger" Content="Stop on retrigger" IsChecked="True"/>
                    <CheckBox x:Name="ChkFadeOut"         Content="Fade out"/>
                    <CheckBox x:Name="ChkVelocity"        Content="Velocity → volume"/>
                </WrapPanel>
                <TextBlock Text="Volume" Margin="0,8,0,3"/>
                <Slider x:Name="SldVolume" Minimum="0" Maximum="1" Value="1"
                        TickFrequency="0.1" IsSnapToTickEnabled="False"/>
                <TextBlock Text="Exclusive group  (same name = only one plays at a time)" Margin="0,8,0,3"/>
                <ComboBox x:Name="CmbGroup" IsEditable="True"/>
            </StackPanel>

            <!-- Command panel -->
            <StackPanel x:Name="PanelCommand" Visibility="Collapsed">
                <TextBlock Text="Executable / command"/>
                <TextBox x:Name="TxtCommand"/>
                <TextBlock Text="Arguments" Margin="0,10,0,3"/>
                <TextBox x:Name="TxtArguments"/>
            </StackPanel>

            <!-- Stop-all panel -->
            <StackPanel x:Name="PanelStopAll" Visibility="Collapsed">
                <TextBlock Text="Press this pad to stop all currently playing sounds."
                           TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="12"/>
            </StackPanel>

            <!-- Lightshow panel -->
            <StackPanel x:Name="PanelLightshow" Visibility="Collapsed">
                <TextBlock Text="Press this pad to run a sequence of LED colors across the grid."
                           TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,10"/>
                <Button x:Name="BtnEditSequence" Content="Edit Sequence…"
                        HorizontalAlignment="Left" Padding="12,6"
                        Click="BtnEditSequence_Click"/>
                <TextBlock x:Name="LblSequenceInfo" Text="No steps configured."
                           Foreground="#6B7280" FontSize="11" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- MIDI Out panel -->
            <StackPanel x:Name="PanelMidi" Visibility="Collapsed">
                <TextBlock Text="Send a MIDI note to another device or DAW when pressed."
                           TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Channel (1-16)"/>
                        <TextBox x:Name="TxtMidiChannel" Text="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Note (0-127)"/>
                        <TextBox x:Name="TxtMidiNote" Text="60"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Velocity (0=pad)"/>
                        <TextBox x:Name="TxtMidiVelocity" Text="0"/>
                    </StackPanel>
                </Grid>
                <CheckBox x:Name="ChkMidiNoteOff" IsChecked="True"
                          Content="Send Note Off on pad release" Foreground="#E5E7EB"/>
            </StackPanel>

            <!-- Macro panel -->
            <StackPanel x:Name="PanelMacro" Visibility="Collapsed">
                <TextBlock Text="Run a sequence of actions when this pad is pressed."
                           TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,10"/>
                <Button x:Name="BtnEditMacro" Content="Edit Macro…"
                        HorizontalAlignment="Left" Padding="12,6"
                        Click="BtnEditMacro_Click"/>
                <TextBlock x:Name="LblMacroInfo" Text="No actions configured."
                           Foreground="#6B7280" FontSize="11" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Volume panel -->
            <StackPanel x:Name="PanelVolume" Visibility="Collapsed">
                <TextBlock Text="Adjust the volume of a running application or the master output."
                           TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Direction"/>
                        <ComboBox x:Name="CmbVolumeDir">
                            <ComboBoxItem Content="Volume Up"   Tag="up"   IsSelected="True"/>
                            <ComboBoxItem Content="Volume Down" Tag="down"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Step (%)"/>
                        <TextBox x:Name="TxtVolumeStep" Text="5"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Target application"/>
                <Grid Margin="0,3,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="CmbVolumeTarget" IsEditable="True"/>
                    <Button Grid.Column="2" Content="Refresh" Click="BtnRefreshApps_Click" Padding="4,4"/>
                </Grid>
                <TextBlock Text='Type "master" for system volume, or pick a running app from the list.'
                           Foreground="#6B7280" FontSize="10" TextWrapping="Wrap" Margin="0,5,0,0"/>
            </StackPanel>

        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Clear Pad" Click="BtnClear_Click" Margin="0,0,8,0"
                    Foreground="#F87171" BorderBrush="#7F1D1D"/>
            <Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button Content="Save" Click="BtnSave_Click"
                    Background="#1D4ED8" BorderBrush="#1E40AF"/>
        </StackPanel>

    </Grid>
</Window>
