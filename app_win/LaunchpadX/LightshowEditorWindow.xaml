<Window x:Class="LaunchpadX.LightshowEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lightshow Editor" Width="720" Height="580"
        Background="#111827" Foreground="#E5E7EB"
        ResizeMode="CanResize" MinWidth="620" MinHeight="480"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#E5E7EB"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E5E7EB"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#374151"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <CheckBox x:Name="ChkLoop" Content="Loop sequence"
                      VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button x:Name="BtnPreview" Content="▶ Preview on Hardware"
                    Click="BtnPreview_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button Content="OK" Click="BtnOk_Click"
                    Background="#1D4ED8" BorderBrush="#1E40AF"/>
        </StackPanel>

        <!-- Right panel: Steps -->
        <DockPanel DockPanel.Dock="Right" Width="210" Margin="12,0,0,0">
            <TextBlock DockPanel.Dock="Top" Text="Steps"
                       Foreground="#6B7280" FontSize="11" Margin="0,0,0,4"/>

            <!-- Step controls (bottom) -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="28"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="+ Add"    Click="BtnAddStep_Click"       Padding="4,5"/>
                    <Button Grid.Column="2" Content="✕ Del"    Click="BtnRemoveStep_Click"    Padding="4,5"/>
                    <Button Grid.Column="4" Content="↑"        Click="BtnMoveUp_Click"        Padding="4,5"/>
                    <Button Grid.Column="6" Content="↓"        Click="BtnMoveDown_Click"      Padding="4,5"/>
                </Grid>
                <Button Content="❑ Duplicate step" Click="BtnDuplicateStep_Click"
                        Padding="4,5" Margin="0,0,0,4"/>
                <Button Content="✎ Generate from text…" Click="BtnGenerateText_Click"
                        Padding="4,5" Margin="0,0,0,6"/>
                <TextBlock Text="Delay before this step (ms)" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtDelay" Text="200" TextChanged="TxtDelay_TextChanged"/>
                <CheckBox x:Name="ChkKeepPrev" Margin="0,10,0,0"
                          Content="Keep previous lights on"
                          Checked="ChkKeepPrev_Changed" Unchecked="ChkKeepPrev_Changed"/>
                <TextBlock x:Name="LblStepInfo" Text="" Foreground="#6B7280"
                           FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Step list -->
            <ListBox x:Name="LstSteps" SelectionChanged="LstSteps_SelectionChanged"/>
        </DockPanel>

        <!-- Left: color picker + pad grid -->
        <DockPanel>
            <!-- Color picker row -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBlock Text="Left-click to paint  ·  Middle-click to pick color from pad  ·  Right-click to erase"
                           Foreground="#6B7280" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TxtColor" Width="90" TextChanged="TxtColor_TextChanged"/>
                    <Border x:Name="ColorPreview"
                            Width="30" Height="24" CornerRadius="4"
                            Background="#FF4400" Margin="6,0,8,0"
                            Cursor="Hand" ToolTip="Click to open color picker"
                            MouseLeftButtonDown="ColorPreview_Click">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                    </Border>
                    <Button Content="Pick…" Click="BtnPickColor_Click" Padding="8,4" Margin="0,0,10,0"/>
                    <!-- Preset swatches -->
                    <UniformGrid Rows="1" Columns="16">
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#FF2222" Tag="#FF2222" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#FF6600" Tag="#FF6600" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#FFCC00" Tag="#FFCC00" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#88FF00" Tag="#88FF00" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#00FF44" Tag="#00FF44" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#00FFCC" Tag="#00FFCC" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#0088FF" Tag="#0088FF" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#8800FF" Tag="#8800FF" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#FF0088" Tag="#FF0088" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#FFAA33" Tag="#FFAA33" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#33FF99" Tag="#33FF99" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#33CCFF" Tag="#33CCFF" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#CC44FF" Tag="#CC44FF" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#FFFFFF" Tag="#FFFFFF" Click="ColorPreset_Click" BorderThickness="0"/>
                        <Button Width="14" Height="24" Padding="0" Margin="1,0" Background="#FF4400" Tag="#FF4400" Click="ColorPreset_Click" BorderThickness="0"/>
                    </UniformGrid>
                </StackPanel>
            </StackPanel>

            <!-- Timeline -->
            <Border DockPanel.Dock="Bottom" Height="52" Margin="0,6,0,0"
                    Background="#0B1220" BorderBrush="#374151" BorderThickness="1"
                    CornerRadius="4">
                <ScrollViewer x:Name="TimelineScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <Canvas x:Name="TimelineCanvas" Height="40" MinWidth="100"/>
                </ScrollViewer>
            </Border>

            <!-- Pad grid -->
            <Viewbox Stretch="Uniform">
                <UniformGrid x:Name="PadGrid" Rows="9" Columns="9" Width="460" Height="460"/>
            </Viewbox>
        </DockPanel>

    </DockPanel>
</Window>
